# 数据库
# 部署原则：所有部署环境都使用远程 PostgreSQL。
# DATABASE_URL 指向当前环境的托管 / 远程 PostgreSQL 实例。
# POSTGRES_* 仅作为脚本和文档里的数据库信息记录；
# Docker 自托管部署不会启动或连接本地 postgres 服务。
POSTGRES_DB=multica
POSTGRES_USER=multica
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgres://user:password@remote-postgres.example.com:5432/multica?sslmode=require
# 可选 pgxpool 调优。默认每个实例 25 / 5，通常够用。
# 也可以在 DATABASE_URL query 中设置 pool_max_conns / pool_min_conns；
# 下面的环境变量优先级高于 URL query 参数。
# DATABASE_MAX_CONNS=25
# DATABASE_MIN_CONNS=5

# 服务端
# APP_ENV 控制生产安全检查。Docker 自托管默认会固定为 production；
# 公开部署建议显式设为 production。
APP_ENV=production
# 本地或测试自动化验证码。公开部署必须留空，避免固定验证码被滥用。
MULTICA_DEV_VERIFICATION_CODE=
PORT=8080
# Prometheus 指标默认关闭。启用时建议只绑定 loopback，
# 除非已经通过私有网络、白名单或代理鉴权保护。
# 不要把该端点暴露到公开的 Web/API 入口。
# 只有启用该监听后，HTTP 请求指标才会开始累计。
# METRICS_ADDR=127.0.0.1:9090
JWT_SECRET=change-me-in-production
# CLI / daemon 连接后端 API 的地址，双域名部署指向 API 域。
MULTICA_SERVER_URL=https://multica-api.example.com
# CLI 登录时打开浏览器的 Web 地址，双域名部署指向 App 域。
MULTICA_APP_URL=https://multica.example.com
MULTICA_DAEMON_CONFIG=
MULTICA_WORKSPACE_ID=
MULTICA_DAEMON_ID=
MULTICA_DAEMON_DEVICE_NAME=
MULTICA_DAEMON_POLL_INTERVAL=3s
MULTICA_DAEMON_HEARTBEAT_INTERVAL=15s
MULTICA_CODEX_PATH=codex
MULTICA_CODEX_MODEL=
MULTICA_CODEX_WORKDIR=
MULTICA_CODEX_TIMEOUT=20m

# 自托管镜像通道
# 默认使用稳定发布通道。如需固定版本，可改成 v0.2.4 这类精确 tag。
# 如果所选 tag 还没有发布到 GHCR，改用 make selfhost-build 从当前代码构建。
MULTICA_IMAGE_TAG=latest
MULTICA_BACKEND_IMAGE=ghcr.io/multica-ai/multica-backend
MULTICA_WEB_IMAGE=ghcr.io/multica-ai/multica-web

# 邮件
# 两种发送方式任选其一即可：
#
# 方式 A：Resend（SaaS，云部署推荐）
#   填写 resend.com 的 API Key，并在 Resend 验证发信域名。
#   本地开发可留空，验证码会打印到 stdout。
#   如需固定本地验证码，配置上面的 MULTICA_DEV_VERIFICATION_CODE；
#   APP_ENV=production 时固定验证码会被忽略。
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@multica.ai
#
# 方式 B：SMTP relay（自托管 / 私有化部署）
#   设置 SMTP_HOST 后优先使用 SMTP。
#   支持无认证 relay（SMTP_USERNAME 留空）和认证 SMTP。
#   只有私有 CA 或自签证书场景才设置 SMTP_TLS_INSECURE=true。
SMTP_HOST=
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS_INSECURE=false

# Google OAuth 登录
# 登录页会在运行时从 /api/config 读取 GOOGLE_CLIENT_ID。
# 修改后只需要重启后端 / compose，不需要重新构建 Web。
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://multica.example.com/auth/callback

# 公司 CAS SSO 登录配置
# 是否启用 CAS 登录。true 时必须填写 CAS_LOGIN_URL、CAS_VALIDATE_URL、CAS_SERVICE_URL。
CAS_ENABLED=false
# 登录页展示名称。包含空格或中文时建议加引号。
CAS_DISPLAY_NAME="公司 SSO"
# CAS 登录地址：用户点击“公司 SSO 登录”后会跳转到这里。
CAS_LOGIN_URL=
# CAS ticket 校验地址：后端 callback 收到 ticket 后会请求这里。
CAS_VALIDATE_URL=
# Multica CAS 回调地址。注意这是 Web 域名下的回调地址，不是 CAS 服务端地址。
CAS_SERVICE_URL=https://multica.example.com/auth/cas/callback
# 邮箱来源字段。常见值为 email；如果 <cas:user> 本身就是邮箱，可填 user。
CAS_ATTRIBUTE_EMAIL=email
# 用户昵称来源字段。
CAS_ATTRIBUTE_NAME=name
# 用户头像来源字段。
CAS_ATTRIBUTE_AVATAR=avatar
# 当 CAS 不返回邮箱、只返回用户名时，可配置邮箱域名用于拼接 username@domain。
CAS_EMAIL_DOMAIN=
# 是否启用邮箱验证码登录。公司 SSO 专用部署可设为 false。
EMAIL_LOGIN_ENABLED=true
# 是否启用 Google 登录。公司 SSO 专用部署可设为 false。
GOOGLE_LOGIN_ENABLED=true
# 是否发送邀请邮件。关闭后只保存 pending invitation，不依赖邮件服务。
INVITATION_EMAIL_ENABLED=true
# 是否在用户登录后自动接受与其邮箱匹配的 pending invitation。
INVITATION_AUTO_ACCEPT_ON_LOGIN=false

# S3 / CloudFront 存储
# S3_BUCKET 只填写 bucket 名称，例如 "my-bucket"。
# 不要包含 ".s3.<region>.amazonaws.com" 后缀；
# 服务端会用 S3_BUCKET + S3_REGION 拼出公开 URL。
# S3_REGION 必须和 bucket 的真实区域一致。
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=multica/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
# COOKIE_DOMAIN 是会话 cookie 和 CloudFront cookie 的可选 Domain 属性。
# 推荐双域名部署下，浏览器仍通过 App 域同源访问 /api、/auth、/ws，
# API 域只给 CLI / daemon 使用，因此这里保持为空即可。
# 只有确认浏览器需要跨子域共享 cookie 时才设置为 ".example.com"。
# 不要设置为 IP 地址，浏览器会丢弃这类 cookie。
COOKIE_DOMAIN=

# 本地文件存储（未配置 S3_BUCKET 时使用）
LOCAL_UPLOAD_DIR=./data/uploads
LOCAL_UPLOAD_BASE_URL=https://multica.example.com

# 安全
# CORS 和 WebSocket 允许的来源，多个值用英文逗号分隔。
# 双域名推荐口径下，浏览器来源只需要允许 App 域。
CORS_ALLOWED_ORIGINS=https://multica.example.com
ALLOWED_ORIGINS=https://multica.example.com

# 实时指标端点 /health/realtime 的访问控制。参见 MUL-1342。
# 未设置时，只允许无转发头的本机 loopback 请求，其他请求返回 404。
# 任何经过 Caddy / Nginx 反向代理的部署都必须设置该 token，
# 因为 Go 层看到的代理请求也像 loopback；未设置 token 会被拒绝。
# 请求时使用 `Authorization: Bearer <token>`。
# REALTIME_METRICS_TOKEN=

# GitHub App 集成（Settings -> Integrations -> Connect GitHub）
# 两项都设置后才会启用连接按钮并接受 webhook；留空表示禁用集成。
# GITHUB_APP_SLUG 是 https://github.com/apps/<slug> 末尾的 slug。
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# 前端
FRONTEND_PORT=3000
# 浏览器访问的 Web 地址，双域名部署指向 App 域。
FRONTEND_ORIGIN=https://multica.example.com
# 推荐保持为空：浏览器按页面来源自动推导，并通过 Next.js rewrite 同源访问后端。
# 只有明确要让浏览器直接跨域访问 API 域时才显式设置。
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=

# 远程 API 代理（可选）。构建 Web 镜像时用于让 Next.js rewrite 连接后端。
# Docker 自托管构建会通过 docker-compose.selfhost.build.yml 注入 http://backend:8080。
# 裸源码部署时可按实际后端地址设置，例如 http://localhost:8080。
# REMOTE_API_URL=http://localhost:8080

# ==================== 自托管：注册控制（修复 #930） ====================
# 设置为 false 可完全关闭新用户注册，私有实例推荐关闭。
ALLOW_SIGNUP=true
# Web UI 会在运行时从 /api/config 读取 ALLOW_SIGNUP。
# 修改后只需要重启后端 / compose，不需要重新构建 Web。
# 该配置不支持热更新。

# 可选：只允许这些邮箱域名注册，多个值用英文逗号分隔。
ALLOWED_EMAIL_DOMAINS=

# 可选：只允许这些具体邮箱注册，多个值用英文逗号分隔。
ALLOWED_EMAILS=

# ==================== 数据分析（PostHog） ====================
# 产品分析事件用于采集 acquisition -> activation -> expansion 漏斗。
# 本地开发 / 自托管实例可留空 POSTHOG_API_KEY；
# 服务端会使用 no-op analytics client，不会上报事件。
# 详见 docs/analytics.md。
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# 可选：覆盖 PostHog event 的 `environment` 属性。
# 默认从 APP_ENV 推导并归一化为 production / staging / dev。
ANALYTICS_ENVIRONMENT=
# 即使设置了 POSTHOG_API_KEY，也强制使用 no-op client，适合 CI 或退出上报。
ANALYTICS_DISABLED=
